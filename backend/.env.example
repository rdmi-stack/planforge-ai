# Application
ENVIRONMENT=development
DEBUG=false

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/planforge

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth / JWT
JWT_SECRET=change-me-to-a-random-64-character-string-in-production

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4001

# AI (GPT-5.4 primary)
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=

# Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-domain.com
MAILGUN_FROM_EMAIL=PlanForge AI <noreply@your-domain.com>
MAILGUN_REGION=US

# Stripe
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# GitHub
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1

# AWS / S3
S3_BUCKET=planforge-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
